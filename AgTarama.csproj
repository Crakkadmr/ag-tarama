<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Lextm.SharpSnmpLib" Version="12.*"/>
  </ItemGroup>

  <!-- tools/ ve Req/ klasörlerini output dizinine kopyala -->
  <ItemGroup>
    <None Include="tools\**\*" CopyToOutputDirectory="PreserveNewest">
      <Link>tools\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
    <None Include="Req\**\*" CopyToOutputDirectory="PreserveNewest">
      <Link>Req\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
  </ItemGroup>

</Project>
