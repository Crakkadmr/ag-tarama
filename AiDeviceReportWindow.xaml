<Window x:Class="AgTarama.AiDeviceReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Cihaz Analizi"
        Background="#0D1117"
        Foreground="#C9D1D9"
        Width="820" Height="640"
        MinWidth="560" MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="ReportBtn" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetChipStyle" TargetType="Button" BasedOn="{StaticResource ReportBtn}">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="TitleText"
                       Text="🤖 AI Cihaz Analizi"
                       FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                       Foreground="#58A6FF"/>
            <TextBlock x:Name="SubtitleText"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="#8B949E" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- İçerik alanı -->
        <Grid Grid.Row="1">

            <!-- Preset seçim paneli -->
            <StackPanel x:Name="PresetPanel" VerticalAlignment="Top">
                <TextBlock Text="Analiz türünü seçin:"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="#8B949E" Margin="0,0,0,12"/>
                <WrapPanel x:Name="PresetChipPanel" Margin="0,0,0,16"/>

                <!-- Özel soru alanı -->
                <Border x:Name="OzelSoruSiniri" Visibility="Collapsed"
                        Background="#161B22" BorderBrush="#30363D"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OzelSoruBox"
                                 Grid.Column="0"
                                 Background="Transparent"
                                 Foreground="#E6EDF3"
                                 CaretBrush="#58A6FF"
                                 SelectionBrush="#1F6FEB"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="13"
                                 AcceptsReturn="False"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OzelSoruBox_KeyDown"/>
                        <Button x:Name="OzelSoruGonderBtn"
                                Grid.Column="2"
                                Style="{StaticResource ReportBtn}"
                                Foreground="#58A6FF"
                                BorderBrush="#1F6FEB"
                                Content="Gönder"
                                Click="OzelSoruGonderBtn_Click"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Bekleme göstergesi -->
            <StackPanel x:Name="BeklemePanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="220" Height="4"
                             Foreground="#58A6FF" Background="#21262D"
                             BorderThickness="0"/>
                <TextBlock Text="AI analiz ediyor..."
                           FontFamily="Consolas" FontSize="13"
                           Foreground="#8B949E"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>
            </StackPanel>

            <!-- Sonuç -->
            <Border x:Name="SonucSiniri" Visibility="Collapsed"
                    Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="SonucBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             Foreground="#E6EDF3"
                             CaretBrush="#58A6FF"
                             SelectionBrush="#1F6FEB"
                             BorderThickness="0"
                             FontFamily="Consolas" FontSize="13"
                             Padding="14"
                             VerticalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Alt buton satırı -->
        <WrapPanel Grid.Row="2" Margin="0,16,0,0">
            <Button x:Name="KopyalaBtn"
                    Style="{StaticResource ReportBtn}"
                    Content="📋  Kopyala"
                    Visibility="Collapsed"
                    Click="KopyalaBtn_Click"/>
            <Button x:Name="TxtKaydetBtn"
                    Style="{StaticResource ReportBtn}"
                    Content="💾  TXT Kaydet"
                    Visibility="Collapsed"
                    Click="TxtKaydetBtn_Click"/>
            <Button x:Name="YenidenSorBtn"
                    Style="{StaticResource ReportBtn}"
                    Content="🔁  Yeniden Sor"
                    Visibility="Collapsed"
                    Click="YenidenSorBtn_Click"/>
            <Button x:Name="IpYenidenTaraBtn"
                    Style="{StaticResource ReportBtn}"
                    Foreground="#3FB950" BorderBrush="#238636"
                    Content="🔄  Bulunan IP'leri yeniden tara"
                    Visibility="Collapsed"
                    Click="IpYenidenTaraBtn_Click"/>
            <Button x:Name="KapatBtn"
                    Style="{StaticResource ReportBtn}"
                    Content="Kapat"
                    Click="KapatBtn_Click"/>
        </WrapPanel>
    </Grid>
</Window>
