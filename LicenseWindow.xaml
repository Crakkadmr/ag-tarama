<Window x:Class="AgTarama.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Sniffer — Lisans Aktivasyonu"
        Height="440" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117"
        ShowInTaskbar="True"
        Loaded="Window_Loaded">

    <Grid Margin="48,36,48,36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Grid.Row="0" Text="Network Sniffer"
                   FontSize="22" FontFamily="Consolas" FontWeight="SemiBold"
                   Foreground="#58A6FF" HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Text="Lisans Aktivasyonu"
                   FontSize="13" FontFamily="Consolas"
                   Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,32"/>

        <!-- Etiket -->
        <TextBlock Grid.Row="2" Text="Lisans Anahtarı"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="#8B949E" Margin="0,0,0,6"/>

        <!-- Anahtar giriş kutusu -->
        <Border Grid.Row="3" x:Name="KeyBorder"
                BorderBrush="#30363D" BorderThickness="1"
                CornerRadius="6" Background="#161B22" Margin="0,0,0,4">
            <TextBox x:Name="TxtKey"
                     FontFamily="Consolas" FontSize="14"
                     Background="Transparent" Foreground="#E6EDF3"
                     BorderThickness="0" Padding="12,10"
                     CaretBrush="#58A6FF" SelectionBrush="#1F4E79"
                     MaxLength="64" CharacterCasing="Upper"
                     GotFocus="TxtKey_GotFocus"
                     TextChanged="TxtKey_TextChanged"/>
        </Border>

        <!-- Durum mesajı -->
        <TextBlock Grid.Row="4" x:Name="TxtStatus"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="#8B949E" TextWrapping="Wrap"
                   MinHeight="36" Margin="0,8,0,20"
                   HorizontalAlignment="Center" TextAlignment="Center"/>

        <!-- Boşluk -->
        <Grid Grid.Row="5"/>

        <!-- Alt butonlar -->
        <StackPanel Grid.Row="6" Orientation="Vertical">
            <!-- Aktive Et butonu -->
            <Button x:Name="BtnActivate" Height="44"
                    FontFamily="Consolas" FontSize="14" FontWeight="SemiBold"
                    Content="Aktive Et"
                    Foreground="White" Cursor="Hand"
                    Click="BtnActivate_Click" Margin="0,0,0,12">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#238636" CornerRadius="6">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border x:Name="Spinner" Visibility="Collapsed"
                                        HorizontalAlignment="Right" Margin="0,0,14,0"
                                        Width="16" Height="16" CornerRadius="8"
                                        BorderBrush="#3FB950" BorderThickness="2">
                                    <Border.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="8" CenterY="8"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Destek iletişim -->
            <TextBlock HorizontalAlignment="Center" FontFamily="Consolas" FontSize="11"
                       Foreground="#484F58" Cursor="Hand"
                       MouseLeftButtonDown="Contact_Click">
                <Run Text="Lisans satın almak veya sorun bildirmek için tıklayın"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
