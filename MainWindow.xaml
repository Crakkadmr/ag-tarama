                                <Button Style="{StaticResource ChipButton}" Tag="80,443,554,8000,8080,37777" Content="Kamera" Click="PortHizliBtn_Click"/>
                            </WrapPanel>
                            <WrapPanel Grid.Row="2" x:Name="PortFavorilerPanel" Margin="0,0,0,4"/>
                            <Grid Grid.Row="3" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PortBaslatBtn" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                        IsEnabled="False" Height="36" HorizontalContentAlignment="Center"
                                        Click="PortBaslatBtn_Click">
                                    <TextBlock Text="▶  Taramayı Başlat" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                                </Button>
                                <Button x:Name="PortFavoriEkleBtn" Grid.Column="2" Content="★"
                                        Style="{StaticResource ActionButton}" IsEnabled="False" Height="36"
                                        HorizontalContentAlignment="Center" ToolTip="Favoriye Ekle"
                                        Click="PortFavoriEkle_Click"/>
                            </Grid>
                        </Grid>
                        <Border x:Name="PortResultBorder" Grid.Row="4" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,4,0,0" Visibility="Collapsed">
                            <ScrollViewer x:Name="PortResultScroll" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="PortResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 4: Traceroute ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="⇢  Traceroute"/>
                </TabItem.Header>
                <Border x:Name="TracePanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="⇢ TRACEROUTE" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Hedefe giden ağ yolunu göster:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <TextBox x:Name="TraceHedefBox" Style="{StaticResource PingInputBox}" Padding="10,8,34,8"
                                     TextChanged="TraceHedefBox_TextChanged" KeyDown="TraceHedefBox_KeyDown"/>
                            <TextBlock x:Name="TraceHedefPlaceholder" Text="Hedef IP veya hostname"
                                       FontFamily="Consolas" FontSize="12" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="TraceHedefValidasyon" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       FontFamily="Consolas" FontSize="15" FontWeight="Bold" IsHitTestVisible="False"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Margin="0,0,0,8">
                            <TextBlock Text="HIZLI SEÇİM" Foreground="#484F58" FontFamily="Consolas" FontSize="10" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <Button Style="{StaticResource ChipButton}" Tag="8.8.8.8"     Content="8.8.8.8"     Click="TraceHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="1.1.1.1"     Content="1.1.1.1"     Click="TraceHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="192.168.1.1" Content="192.168.1.1" Click="TraceHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="google.com"  Content="google.com"  Click="TraceHizliBtn_Click"/>
                            </WrapPanel>
                        </StackPanel>
                        <Button x:Name="TraceBaslatBtn" Grid.Row="3" Style="{StaticResource PrimaryButton}"
                                IsEnabled="False" Height="36" HorizontalContentAlignment="Center"
                                Click="TraceBaslatBtn_Click" Margin="0,0,0,6">
                            <TextBlock Text="⇢  Rotayı Takip Et" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                        </Button>
                        <Border x:Name="TraceResultBorder" Grid.Row="4" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,4,0,0" Visibility="Collapsed">
                            <ScrollViewer x:Name="TraceResultScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="TraceResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 5: DNS Lookup ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="⊕  DNS Lookup"/>
                </TabItem.Header>
                <Border x:Name="DnsPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="⊕ DNS LOOKUP" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Hostname↔IP çözümle:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBox x:Name="DnsHedefBox" Style="{StaticResource PingInputBox}" Padding="10,8,10,8"
                                     TextChanged="DnsHedefBox_TextChanged" KeyDown="DnsHedefBox_KeyDown"/>
                            <TextBlock x:Name="DnsHedefPlaceholder" Text="IP veya hostname"
                                       FontFamily="Consolas" FontSize="12" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Button x:Name="DnsBaslatBtn" Grid.Row="2" Style="{StaticResource PrimaryButton}"
                                IsEnabled="False" Height="36" HorizontalContentAlignment="Center"
                                Click="DnsBaslatBtn_Click" Margin="0,0,0,6">
                            <TextBlock Text="⊕  Çözümle" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                        </Button>
                        <Border x:Name="DnsResultBorder" Grid.Row="3" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,4,0,0" Visibility="Collapsed">
                            <ScrollViewer x:Name="DnsResultScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="DnsResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 6: Wake-on-LAN ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="⏻  Wake-on-LAN"/>
                </TabItem.Header>
                <Border x:Name="WolPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="⏻ WAKE-ON-LAN" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="MAC adresine magic packet gönder:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBox x:Name="WolMacBox" Style="{StaticResource PingInputBox}" Padding="10,8,34,8"
                                     TextChanged="WolMacBox_TextChanged" KeyDown="WolMacBox_KeyDown"/>
                            <TextBlock x:Name="WolMacPlaceholder" Text="MAC: AA:BB:CC:DD:EE:FF"
                                       FontFamily="Consolas" FontSize="11" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="WolMacValidasyon" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       FontFamily="Consolas" FontSize="15" FontWeight="Bold" IsHitTestVisible="False"/>
                        </Grid>
                        <Button x:Name="WolGonderBtn" Grid.Row="2" Style="{StaticResource PrimaryButton}"
                                IsEnabled="False" Height="36" HorizontalContentAlignment="Center"
                                Click="WolGonderBtn_Click" Margin="0,0,0,6">
                            <TextBlock Text="⏻  Magic Packet Gönder" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                        </Button>
                        <Border x:Name="WolResultBorder" Grid.Row="3" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,4,0,0" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="WolResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 7: Favoriler ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="★  Favoriler"/>
                </TabItem.Header>
                <Border x:Name="FavorilerPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="★ FAVORİLER" Foreground="#58A6FF" FontFamily="Consolas"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Sık kullanılan IP adresleri:" Foreground="#8B949E"
                                       FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="FavorilerListePanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 8: Bant Genişliği ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="▶  Bant Genişliği"/>
                </TabItem.Header>
                <Border x:Name="BantPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="▶ BANT GENİŞLİĞİ" Foreground="#58A6FF" FontFamily="Consolas"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="BantDurumText" Text="Ağ adaptörleri izleniyor..."
                                       Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="BantAdaptorPanel" Margin="8,6,8,6"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 9: Geçmiş ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="◷  Geçmiş"/>
                </TabItem.Header>
                <Border x:Name="GecmisPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="◷ GEÇMİŞ" Foreground="#58A6FF" FontFamily="Consolas"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Ping, port, cihaz, ARP ve yakalama kayıtları:"
                                       Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Yenile" Style="{StaticResource ChipButton}" Click="GecmisYenile_Click"/>
                            <Button Content="Klasörü Aç" Style="{StaticResource ChipButton}" Click="GecmisKlasorAc_Click"/>
                            <Button Content="Son Cihaz Taramalarını Karşılaştır" Style="{StaticResource ChipButton}" Click="GecmisKarsilastir_Click"/>
                            <Button Content="Tümünü Temizle" Style="{StaticResource ChipButton}" Click="GecmisTumunuTemizle_Click"
                                    Foreground="#F85149"/>
                        </WrapPanel>
                        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                            <TextBlock Text="Filtre:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Button x:Name="GecmisFiltreTumu"  Content="Tümü"       Tag=""          Style="{StaticResource ChipButton}" Click="GecmisFiltreBtn_Click"/>
                            <Button x:Name="GecmisFiltreYakalama" Content="YAKALAMA"   Tag="YAKALAMA"  Style="{StaticResource ChipButton}" Click="GecmisFiltreBtn_Click"/>
                            <Button x:Name="GecmisFiltreKamera"   Content="CİHAZ TARA" Tag="CİHAZ TARA" Style="{StaticResource ChipButton}" Click="GecmisFiltreBtn_Click"/>
                            <Button x:Name="GecmisFiltrePing"     Content="PING"        Tag="PING"       Style="{StaticResource ChipButton}" Click="GecmisFiltreBtn_Click"/>
                            <Button x:Name="GecmisFiltrePort"     Content="PORT TARA"  Tag="PORT TARA"  Style="{StaticResource ChipButton}" Click="GecmisFiltreBtn_Click"/>
                            <Button x:Name="GecmisFiltreArp"      Content="ARP"         Tag="ARP"        Style="{StaticResource ChipButton}" Click="GecmisFiltreBtn_Click"/>
                        </WrapPanel>
                        <Border Grid.Row="3" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="GecmisListePanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>

        <!-- Toast bildirimi (sağ alt köşe) -->
        <Border x:Name="ToastBildirim"
                Grid.RowSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Background="#1C2128"
                BorderBrush="#3FB950"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Visibility="Collapsed"
                Panel.ZIndex="200">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIkon" Text="✔" Foreground="#3FB950"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="ToastMetin" Foreground="#E6EDF3"
                           FontFamily="Consolas" FontSize="12" MaxWidth="260"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
