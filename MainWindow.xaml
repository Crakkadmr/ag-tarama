<Window x:Class="AgTarama.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ağ Tarama Programı" Height="650" Width="1000"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Buton stili -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D3B66"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Birincil aksiyon butonu (Taramayı Başlat) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#1A4A2E"/>
            <Setter Property="Foreground" Value="#3FB950"/>
            <Setter Property="BorderBrush" Value="#238636"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22623C"/>
                                <Setter Property="BorderBrush" Value="#3FB950"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3D20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Durdur butonu -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3D1A1A"/>
            <Setter Property="Foreground" Value="#F85149"/>
            <Setter Property="BorderBrush" Value="#8B1A1A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4D2020"/>
                                <Setter Property="BorderBrush" Value="#F85149"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D0F0F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar stili -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- SOL: Chat alanı -->
        <Grid Grid.Column="0" Margin="16,16,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Başlık -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="AG TARAMA"
                           Foreground="#58A6FF"
                           FontSize="20"
                           FontWeight="Bold"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="StatusText"
                           Text="● Hazır"
                           Foreground="#3FB950"
                           FontSize="11"
                           FontFamily="Consolas"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Mesaj alanı -->
            <Border Grid.Row="1"
                    Background="#0D1117"
                    BorderBrush="#21262D"
                    BorderThickness="1"
                    CornerRadius="8">
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="4,4,8,4">
                    <StackPanel x:Name="ChatPanel" Margin="8,8,4,8"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Dikey ayırıcı -->
        <Rectangle Grid.Column="0"
                   HorizontalAlignment="Right"
                   Width="1"
                   Fill="#21262D"
                   Margin="0,16,0,16"/>

        <!-- SAĞ: Kontrol paneli -->
        <Grid Grid.Column="1" Margin="8,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Panel başlığı -->
            <TextBlock Grid.Row="0"
                       Text="KONTROL"
                       Foreground="#8B949E"
                       FontSize="11"
                       FontWeight="Bold"
                       FontFamily="Consolas"
                       Margin="0,0,0,12"/>

            <!-- Butonlar -->
            <StackPanel Grid.Row="1">

                <!-- Taramayı Başlat -->
                <Button x:Name="BtnTaramaBaslat"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnTaramaBaslat_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶  " FontSize="13"/>
                        <TextBlock Text="Taramayı Başlat" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Taramayı Durdur -->
                <Button x:Name="BtnTaramaDurdur"
                        Style="{StaticResource DangerButton}"
                        IsEnabled="False"
                        Click="BtnTaramaDurdur_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="■  " FontSize="13"/>
                        <TextBlock Text="Taramayı Durdur" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Ayırıcı -->
                <Rectangle Height="1" Fill="#21262D" Margin="0,8,0,8"/>

                <!-- Ping Testi -->
                <Button x:Name="BtnPing"
                        Style="{StaticResource ActionButton}"
                        Click="BtnPing_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="◈  " FontSize="13"/>
                        <TextBlock Text="Ping Testi" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Port Tara -->
                <Button x:Name="BtnPortTara"
                        Style="{StaticResource ActionButton}"
                        Click="BtnPortTara_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊞  " FontSize="13"/>
                        <TextBlock Text="Port Tara" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Cihazları Listele -->
                <Button x:Name="BtnCihazlar"
                        Style="{StaticResource ActionButton}"
                        Click="BtnCihazlar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="≡  " FontSize="13"/>
                        <TextBlock Text="Cihazları Listele" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Ayırıcı -->
                <Rectangle Height="1" Fill="#21262D" Margin="0,8,0,8"/>

                <!-- Temizle -->
                <Button x:Name="BtnTemizle"
                        Style="{StaticResource ActionButton}"
                        Click="BtnTemizle_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌫  " FontSize="13"/>
                        <TextBlock Text="Ekranı Temizle" FontSize="13"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Alt: Versiyon bilgisi -->
            <TextBlock Grid.Row="2"
                       Text="v0.1.0 — Ağ Tarama"
                       Foreground="#484F58"
                       FontSize="10"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
