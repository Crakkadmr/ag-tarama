                                       FontFamily="Consolas" FontSize="11" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Grid Grid.Row="3" Margin="0,0,0,4">
