                                <Button Style="{StaticResource ChipButton}"
                                        Tag="21,22,23,25,53,80,110,135,139,143,443,445,587,993,995,1433,3306,3389,5900,8080"
                                        Content="Yaygın 20" Click="PortHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="80,443,8080,8443" Content="Web" Click="PortHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="22,3389" Content="SSH+RDP" Click="PortHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="80,443,554,8000,8080,37777" Content="Kamera" Click="PortHizliBtn_Click"/>
                            </WrapPanel>
                            <WrapPanel Grid.Row="2" x:Name="PortFavorilerPanel" Margin="0,0,0,4"/>
                            <Grid Grid.Row="3" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PortBaslatBtn" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                        IsEnabled="False" Height="36" HorizontalContentAlignment="Center"
                                        Click="PortBaslatBtn_Click">
                                    <TextBlock Text="▶  Taramayı Başlat" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                                </Button>
                                <Button x:Name="PortFavoriEkleBtn" Grid.Column="2" Content="★"
                                        Style="{StaticResource ActionButton}" IsEnabled="False" Height="36"
                                        HorizontalContentAlignment="Center" ToolTip="Favoriye Ekle"
                                        Click="PortFavoriEkle_Click"/>
                            </Grid>
                        </Grid>
                        <Border x:Name="PortResultBorder" Grid.Row="4" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,4,0,0" Visibility="Collapsed">
                            <ScrollViewer x:Name="PortResultScroll" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="PortResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 4: Traceroute ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="⇢  Traceroute"/>
                </TabItem.Header>
                <Border x:Name="TracePanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="⇢ TRACEROUTE" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Hedefe giden ağ yolunu göster:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <TextBox x:Name="TraceHedefBox" Style="{StaticResource PingInputBox}" Padding="10,8,34,8"
