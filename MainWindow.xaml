                                Click="WolGonderBtn_Click" Margin="0,0,0,6">
                            <TextBlock Text="⏻  Magic Packet Gönder" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                        </Button>
                        <Border x:Name="WolResultBorder" Grid.Row="3" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,4,0,0" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="WolResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 7: Favoriler ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="★  Favoriler"/>
                </TabItem.Header>
                <Border x:Name="FavorilerPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
