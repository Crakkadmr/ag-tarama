<Window x:Class="AgTarama.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ağ Tarama Programı" Height="650" Width="1000"
        MinHeight="500" MinWidth="750"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <!-- Buton stili -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D3B66"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aktif panel butonu (yeşil çerçeve, hover'da arka plan değişir ama çerçeve korunur) -->
        <Style x:Key="ActiveActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0D1F12"/>
            <Setter Property="Foreground" Value="#3FB950"/>
            <Setter Property="BorderBrush" Value="#3FB950"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#162B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3D20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Birincil aksiyon butonu (Taramayı Başlat) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#1A4A2E"/>
            <Setter Property="Foreground" Value="#3FB950"/>
            <Setter Property="BorderBrush" Value="#238636"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22623C"/>
                                <Setter Property="BorderBrush" Value="#3FB950"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3D20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Durdur butonu -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3D1A1A"/>
            <Setter Property="Foreground" Value="#F85149"/>
            <Setter Property="BorderBrush" Value="#8B1A1A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4D2020"/>
                                <Setter Property="BorderBrush" Value="#F85149"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D0F0F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar stili -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>

        <!-- Ping giriş kutusu -->
        <Style x:Key="PingInputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="SelectionBrush" Value="#1F6FEB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hızlı seçim chip butonu -->
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D3B66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Uygulama içi koyu ToolTip stili -->
        <Style TargetType="ToolTip">
            <Setter Property="Background"       Value="#1C2128"/>
            <Setter Property="Foreground"       Value="#C9D1D9"/>
            <Setter Property="BorderBrush"      Value="#3D444D"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="HasDropShadow"    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                MaxWidth="280">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- SOL: Chat alanı -->
        <Grid Grid.Column="0" Margin="16,16,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Başlık -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="AG TARAMA"
                           Foreground="#58A6FF"
                           FontSize="20"
                           FontWeight="Bold"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="StatusText"
                           Text="● Hazır"
                           Foreground="#3FB950"
                           FontSize="11"
                           FontFamily="Consolas"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Mesaj alanı + Ping paneli -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="PingCol" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Ana chat -->
                <Border Grid.Column="0"
                        Background="#0D1117"
                        BorderBrush="#21262D"
                        BorderThickness="1"
                        CornerRadius="8">
                    <ScrollViewer x:Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4,4,8,4">
                        <StackPanel x:Name="ChatPanel" Margin="8,8,4,8"/>
                    </ScrollViewer>
                </Border>

                <!-- Ping paneli (animasyonla açılır) -->
                <Grid Grid.Column="1" x:Name="PingPanel" ClipToBounds="True">
                    <Border Background="#0D1117"
                            BorderBrush="#21262D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="8,0,0,0">
                        <Grid Margin="14,14,14,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Başlık -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="◈ PING TESTİ"
                                           Foreground="#58A6FF"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Hangi IP'ye atmak istiyorsunuz?"
                                           Foreground="#8B949E"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- IP giriş alanı -->
                            <Grid Grid.Row="1" Margin="0,0,0,16">
                                <TextBox x:Name="PingIpBox"
                                         Style="{StaticResource PingInputBox}"
                                         Padding="10,8,34,8"
                                         TextChanged="PingIpBox_TextChanged"
                                         KeyDown="PingIpBox_KeyDown"/>
                                <TextBlock x:Name="PingPlaceholder"
                                           Text="Örn: 192.168.1.1"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Foreground="#484F58"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           IsHitTestVisible="False"/>
                                <TextBlock x:Name="PingValidasyonIkonu"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontFamily="Consolas"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Hızlı seçenekler -->
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="HIZLI SEÇİM"
                                           Foreground="#484F58"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource ChipButton}" Tag="192.168.1.1"   Content="192.168.1.1"   Click="PingHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}" Tag="192.168.1.254" Content="192.168.1.254" Click="PingHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}" Tag="8.8.8.8"       Content="8.8.8.8"       Click="PingHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}" Tag="1.1.1.1"       Content="1.1.1.1"       Click="PingHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}" Tag="8.8.4.4"       Content="8.8.4.4"       Click="PingHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}" Tag="google.com"    Content="google.com"    Click="PingHizliBtn_Click"/>
                                </WrapPanel>
                                <!-- Dinamik favori chip'leri -->
                                <WrapPanel x:Name="PingFavorilerPanel" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Başlat + Favoriye Ekle -->
                            <Grid Grid.Row="3" Margin="0,8,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PingBaslatBtn"
                                        Grid.Column="0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="False"
                                        Height="36"
                                        HorizontalContentAlignment="Center"
                                        Click="PingBaslatBtn_Click">
                                    <TextBlock Text="◈  Ping Başlat"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Button>
                                <Button x:Name="PingFavoriEkleBtn"
                                        Grid.Column="2"
                                        Content="★"
                                        Style="{StaticResource ActionButton}"
                                        IsEnabled="False"
                                        Height="36"
                                        HorizontalContentAlignment="Center"
                                        ToolTip="Favoriye Ekle"
                                        Click="PingFavoriEkle_Click"/>
                            </Grid>

                            <!-- Ping sonuç kutusu -->
                            <Border x:Name="PingResultBorder"
                                    Grid.Row="4"
                                    Background="#0D1117"
                                    BorderBrush="#21262D"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <ScrollViewer x:Name="PingResultScroll"
                                              MaxHeight="180"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="PingResultPanel"
                                                Margin="10,8,10,8"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Kapat -->
                            <Button Grid.Row="5"
                                    Content="✕  Kapat"
                                    Style="{StaticResource ActionButton}"
                                    Click="PingPanelKapat_Click"
                                    Margin="0,10,0,0"
                                    HorizontalContentAlignment="Center"
                                    Foreground="#8B949E"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Port Tara paneli (animasyonla açılır) -->
                <Grid Grid.Column="1" x:Name="PortPanel" ClipToBounds="True" Visibility="Collapsed">
                    <Border Background="#0D1117"
                            BorderBrush="#21262D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="8,0,0,0">
                        <Grid Margin="14,14,14,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Başlık -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="⊞ PORT TARA"
                                           Foreground="#58A6FF"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="IP ve port aralığı girin:"
                                           Foreground="#8B949E"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- IP giriş -->
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <TextBox x:Name="PortIpBox"
                                         Style="{StaticResource PingInputBox}"
                                         Padding="10,8,34,8"
                                         TextChanged="PortIpBox_TextChanged"
                                         KeyDown="PortIpBox_KeyDown"/>
                                <TextBlock x:Name="PortIpPlaceholder"
                                           Text="Hedef IP"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Foreground="#484F58"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           IsHitTestVisible="False"/>
                                <TextBlock x:Name="PortIpValidasyon"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontFamily="Consolas"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Port aralığı giriş -->
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <TextBox x:Name="PortAralikBox"
                                         Style="{StaticResource PingInputBox}"
                                         Padding="10,8,10,8"
                                         TextChanged="PortAralikBox_TextChanged"/>
                                <TextBlock x:Name="PortAralikPlaceholder"
                                           Text="Portlar: 1-1024, 80,443"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="#484F58"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Hızlı seçim + Başlat -->
                            <Grid Grid.Row="3" Margin="0,0,0,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="HIZLI SEÇİM"
                                           Foreground="#484F58"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Margin="0,0,0,6"/>
                                <WrapPanel Grid.Row="1" Margin="0,0,0,4">
                                    <Button Style="{StaticResource ChipButton}"
                                            Tag="21,22,23,25,53,80,110,135,139,143,443,445,587,993,995,1433,3306,3389,5900,8080"
                                            Content="Yaygın 20" Click="PortHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}"
                                            Tag="80,443,8080,8443"
                                            Content="Web" Click="PortHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}"
                                            Tag="22,3389"
                                            Content="SSH+RDP" Click="PortHizliBtn_Click"/>
                                    <Button Style="{StaticResource ChipButton}"
                                            Tag="80,443,554,8000,8080,37777"
                                            Content="Kamera" Click="PortHizliBtn_Click"/>
                                </WrapPanel>
                                <!-- Dinamik favori chip'leri -->
                                <WrapPanel Grid.Row="2" x:Name="PortFavorilerPanel" Margin="0,0,0,4"/>
                                <!-- Başlat + Favoriye Ekle -->
                                <Grid Grid.Row="3" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PortBaslatBtn"
                                            Grid.Column="0"
                                            Style="{StaticResource PrimaryButton}"
                                            IsEnabled="False"
                                            Height="36"
                                            HorizontalContentAlignment="Center"
                                            Click="PortBaslatBtn_Click">
                                        <TextBlock Text="▶  Taramayı Başlat"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Button>
                                    <Button x:Name="PortFavoriEkleBtn"
                                            Grid.Column="2"
                                            Content="★"
                                            Style="{StaticResource ActionButton}"
                                            IsEnabled="False"
                                            Height="36"
                                            HorizontalContentAlignment="Center"
                                            ToolTip="Favoriye Ekle"
                                            Click="PortFavoriEkle_Click"/>
                                </Grid>
                            </Grid>

                            <!-- Sonuç kutusu -->
                            <Border x:Name="PortResultBorder"
                                    Grid.Row="4"
                                    Background="#0D1117"
                                    BorderBrush="#21262D"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,4,0,0"
                                    Visibility="Collapsed">
                                <ScrollViewer x:Name="PortResultScroll"
                                              MaxHeight="160"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="PortResultPanel"
                                                Margin="10,8,10,8"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Kapat -->
                            <Button Grid.Row="5"
                                    Content="✕  Kapat"
                                    Style="{StaticResource ActionButton}"
                                    Click="PortPanelKapat_Click"
                                    Margin="0,10,0,0"
                                    HorizontalContentAlignment="Center"
                                    Foreground="#8B949E"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Traceroute paneli -->
                <Grid Grid.Column="1" x:Name="TracePanel" ClipToBounds="True" Visibility="Collapsed">
                    <Border Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                        <Grid Margin="14,14,14,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="⇢ TRACEROUTE" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="Hedefe giden ağ yolunu göster:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <TextBox x:Name="TraceHedefBox" Style="{StaticResource PingInputBox}" Padding="10,8,34,8"
                                         TextChanged="TraceHedefBox_TextChanged" KeyDown="TraceHedefBox_KeyDown"/>
                                <TextBlock x:Name="TraceHedefPlaceholder" Text="Hedef IP veya hostname"
                                           FontFamily="Consolas" FontSize="12" Foreground="#484F58"
                                           VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                <TextBlock x:Name="TraceHedefValidasyon" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
