            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#111827" BorderBrush="#243147"
                    BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" Padding="12,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="KOMUT KONSOLU" Foreground="#58A6FF"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="   F12: aç/kapat  •  Tab: tamamla  •  ↑↓: geçmiş  •  Esc: iptal"
                                   Foreground="#484F58" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Style="{StaticResource ChipButton}"
                            Padding="6,2" Click="ConsoleKapat_Click"/>
                </Grid>
            </Border>
            <ScrollViewer x:Name="ConsoleScrollViewer" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="#070B10">
                <TextBox x:Name="ConsoleOutput"
                         FontFamily="Consolas" FontSize="12"
                         Foreground="#C9D1D9" Background="Transparent"
                         BorderThickness="0" IsReadOnly="True"
                         TextWrapping="Wrap" Padding="12,6"
                         AcceptsReturn="True" IsTabStop="False"/>
            </ScrollViewer>
            <Border Grid.Row="2" Background="#111827" BorderBrush="#243147"
                    BorderThickness="1,0,1,1" CornerRadius="0,0,6,6" Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="▶ " Foreground="#58A6FF" FontFamily="Consolas"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBox x:Name="ConsoleInput" Grid.Column="1"
                             FontFamily="Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#E6EDF3" CaretBrush="#58A6FF"
                             VerticalAlignment="Center"
                             KeyDown="ConsoleInput_KeyDown"/>
                </Grid>
            </Border>
        </Grid>

        </Grid>

        <!-- Toast bildirimi (sağ alt köşe) -->
        <Border x:Name="ToastBildirim"
                Grid.RowSpan="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Background="#1C2128"
                BorderBrush="#3FB950"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Visibility="Collapsed"
                Panel.ZIndex="200">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIkon" Text="✔" Foreground="#3FB950"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="ToastMetin" Foreground="#E6EDF3"
                           FontFamily="Consolas" FontSize="12" MaxWidth="260"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

