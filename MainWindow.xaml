                                   Foreground="#58A6FF88" FontFamily="Consolas" FontSize="9"
                                   Margin="0,2,2,0" IsHitTestVisible="False"/>
                    </Grid>
                </Button>

                <!-- Ayırıcı -->
                <Rectangle Height="1" Fill="#21262D" Margin="0,8,0,8"/>

                <!-- Favoriler -->
                <Button x:Name="BtnFavoriler"
                        Style="{StaticResource ActionButton}"
                        HorizontalContentAlignment="Stretch"
                        Click="BtnFavoriler_Click"
                        ToolTip="Sık kullanılan IP adreslerini kaydeder. Ping, port tarama gibi işlemlerde tek tıkla hedef seçimi sağlar.">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="★  " FontSize="13"/>
                            <TextBlock Text="Favoriler" FontSize="13"/>
                        </StackPanel>
                        <TextBlock Text="ⓘ" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Foreground="#58A6FF88" FontFamily="Consolas" FontSize="9"
                                   Margin="0,2,2,0" IsHitTestVisible="False"/>
                    </Grid>
                </Button>

                <!-- Bant Genişliği -->
                <Button x:Name="BtnBant"
                        Style="{StaticResource ActionButton}"
                        HorizontalContentAlignment="Stretch"
                        Click="BtnBant_Click"
                        ToolTip="Ağ adaptörlerinin gerçek zamanlı indirme/yükleme hızlarını gösterir. Hangi adaptörün bant yediğini anlık olarak izler.">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="▶  " FontSize="13"/>
                            <TextBlock Text="Bant Genişliği" FontSize="13"/>
                        </StackPanel>
                        <TextBlock Text="ⓘ" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Foreground="#58A6FF88" FontFamily="Consolas" FontSize="9"
                                   Margin="0,2,2,0" IsHitTestVisible="False"/>
                    </Grid>
                </Button>

                <!-- Rapor Kaydet -->
                <Button x:Name="BtnRapor"
                        Style="{StaticResource ActionButton}"
                        HorizontalContentAlignment="Stretch"
                        Click="BtnRapor_Click"
                        ToolTip="Chat panelindeki tüm sonuçları ve log kayıtlarını metin dosyası (.txt) olarak dışa aktarır.">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="▤  " FontSize="13"/>
                            <TextBlock Text="Rapor Kaydet" FontSize="13"/>
                        </StackPanel>
                        <TextBlock Text="ⓘ" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Foreground="#58A6FF88" FontFamily="Consolas" FontSize="9"
                                   Margin="0,2,2,0" IsHitTestVisible="False"/>
                    </Grid>
                </Button>

                <!-- Ayarlar -->
                <Button x:Name="BtnAyarlar"
                        Style="{StaticResource ActionButton}"
                        HorizontalContentAlignment="Stretch"
                        Click="BtnAyarlar_Click"
                        ToolTip="Uygulama ayarlarını düzenler: tema, timeout süreleri, log tercihleri ve başlangıç davranışı.">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="⚙  " FontSize="13"/>
                            <TextBlock Text="Ayarlar" FontSize="13"/>
                        </StackPanel>
                        <TextBlock Text="ⓘ" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Foreground="#58A6FF88" FontFamily="Consolas" FontSize="9"
                                   Margin="0,2,2,0" IsHitTestVisible="False"/>
                    </Grid>
                </Button>

                <!-- Ayırıcı -->
                <Rectangle Height="1" Fill="#21262D" Margin="0,8,0,8"/>

                <!-- Temizle -->
                <Button x:Name="BtnTemizle"
                        Style="{StaticResource ActionButton}"
                        HorizontalContentAlignment="Stretch"
                        Click="BtnTemizle_Click"
                        ToolTip="Chat panelindeki tüm mesajları temizler. Aktif paket yakalama sırasında bu buton devre dışıdır.">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="⌫  " FontSize="13"/>
                            <TextBlock Text="Ekranı Temizle" FontSize="13"/>
                        </StackPanel>
                        <TextBlock Text="ⓘ" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Foreground="#58A6FF88" FontFamily="Consolas" FontSize="9"
                                   Margin="0,2,2,0" IsHitTestVisible="False"/>
                    </Grid>
                </Button>

            </StackPanel>
            </ScrollViewer>

            <!-- Alt: Versiyon bilgisi -->
            <TextBlock Grid.Row="2"
                       Text="v0.1.0 — Ağ Tarama"
                       Foreground="#484F58"
                       FontSize="10"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"/>
        </Grid>

        <!-- Toast bildirimi overlay (tüm kolonları kaplar, sağ alt köşe) -->
        <Border x:Name="ToastBildirim"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Background="#1C2128"
                BorderBrush="#3FB950"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Visibility="Collapsed"
                Panel.ZIndex="200">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIkon"
                           Text="✔"
                           Foreground="#3FB950"
                           FontFamily="Consolas"
                           FontSize="13"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock x:Name="ToastMetin"
                           Foreground="#E6EDF3"
                           FontFamily="Consolas"
                           FontSize="12"
                           MaxWidth="260"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
