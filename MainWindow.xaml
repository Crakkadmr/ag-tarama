<Window x:Class="AgTarama.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prim="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Network Sniffer - Made by Demircan" Height="720" Width="1180"
        Icon="pack://application:,,,/app.ico"
        MinHeight="620" MinWidth="1100"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <!-- Buton stili -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D3B66"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aktif panel butonu (yeşil çerçeve, hover'da arka plan değişir ama çerçeve korunur) -->
        <Style x:Key="ActiveActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0D1F12"/>
            <Setter Property="Foreground" Value="#3FB950"/>
            <Setter Property="BorderBrush" Value="#3FB950"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#162B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3D20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Birincil aksiyon butonu (Taramayı Başlat) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#1A4A2E"/>
            <Setter Property="Foreground" Value="#3FB950"/>
            <Setter Property="BorderBrush" Value="#238636"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22623C"/>
                                <Setter Property="BorderBrush" Value="#3FB950"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3D20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Durdur butonu -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3D1A1A"/>
            <Setter Property="Foreground" Value="#F85149"/>
            <Setter Property="BorderBrush" Value="#8B1A1A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4D2020"/>
                                <Setter Property="BorderBrush" Value="#F85149"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D0F0F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                                <Setter Property="BorderBrush" Value="#21262D"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar stili -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>

        <!-- Ping giriş kutusu -->
        <Style x:Key="PingInputBox" TargetType="TextBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="SelectionBrush" Value="#1F6FEB"/>
            <Setter Property="SelectionTextBrush" Value="#E6EDF3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- AI input kutusunun minimal iç stili — görsel çerçeve parent Border'dan gelir -->
        <Style x:Key="AiInputStyle" TargetType="TextBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="SelectionBrush" Value="#1F6FEB"/>
            <Setter Property="SelectionTextBrush" Value="#E6EDF3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      Background="Transparent"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hızlı seçim chip butonu -->
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D3B66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#111827"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2F81F7"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0D3B66"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="6"
                                                Padding="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <ContentPresenter x:Name="ContentSite"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Margin="0,0,22,0"/>
                                                <Path x:Name="Arrow"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#58A6FF"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#58A6FF"/>
                                                <Setter TargetName="ComboBorder" Property="Background" Value="#111827"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#58A6FF"/>
                                                <Setter TargetName="ComboBorder" Property="Background" Value="#0D1F2F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#0D1117"
                                        BorderBrush="#2F81F7"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
            <Setter Property="BorderBrush" Value="#243147"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="9,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#182233"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0D3B66"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="MinHeight" Value="34"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#101722"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#152033"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0D3B66"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#243147"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource DarkDataGridColumnHeader}"/>
            <Setter Property="CellStyle" Value="{StaticResource DarkDataGridCell}"/>
            <Setter Property="RowStyle" Value="{StaticResource DarkDataGridRow}"/>
        </Style>

        <Style x:Key="FlatContextMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D3B66"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Koyu temalı ToggleButton (subnet chip'i için) -->
        <Style x:Key="DarkChip" TargetType="{x:Type prim:ToggleButton}">
            <Setter Property="Background" Value="#1F2933"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type prim:ToggleButton}">
                        <Border x:Name="ChipBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#0F376D"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#2F81F7"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChipBorder" Property="Background" Value="#243140"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#58A6FF"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Koyu temalı CheckBox: Windows varsayılan görsel/temasını override eder -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="6,0,0,0"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Box"
                                    Width="16" Height="16"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="CheckMark"
                                      Stroke="#58A6FF" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="M 3 8 L 7 12 L 13 4"
                                      Stretch="None"
                                      Visibility="Collapsed"
                                      SnapsToDevicePixels="True"/>
                            </Border>
                            <ContentPresenter x:Name="Content"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter TargetName="Box" Property="Background" Value="#0D3B66"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tum CheckBox'lara varsayilan olarak koyu temayi uygula -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource DarkCheckBox}"/>

        <Style x:Key="FlatContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Uygulama içi koyu ToolTip stili -->
        <Style TargetType="ToolTip">
            <Setter Property="Background"       Value="#1C2128"/>
            <Setter Property="Foreground"       Value="#C9D1D9"/>
            <Setter Property="BorderBrush"      Value="#3D444D"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="HasDropShadow"    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                MaxWidth="280">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#07111F" Offset="0"/>
                <GradientStop Color="#0D1117" Offset="0.45"/>
                <GradientStop Color="#111827" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık (tam genişlik) -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#243147"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,14"
                Margin="16,16,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="NETWORK SNIFFER"
                               Foreground="#E6EDF3" FontSize="28" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Text="packet capture | device discovery | network diagnostics"
                               Foreground="#8B949E" FontSize="11" FontFamily="Consolas" Margin="1,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="● Hazır"
                               Foreground="#3FB950" FontSize="12" FontWeight="Bold"
                               FontFamily="Consolas" HorizontalAlignment="Right"/>
                    <Border Background="#0D1F2F" BorderBrush="#1F6FEB" BorderThickness="1"
                            CornerRadius="10" Padding="10,4" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="made by demircan"
                                       Foreground="#58A6FF" FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock x:Name="VersionText" Text="v0.1.0"
                                       Foreground="#484F58" FontSize="10" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Lisans sona erme uyarı banner -->
        <Border x:Name="LisansBanner" Grid.Row="1" Visibility="Collapsed"
                Background="#1F1400" BorderBrush="#D29A22" BorderThickness="0,0,0,1"
                Padding="16,6" Margin="16,4,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚠  " Foreground="#D29A22" FontFamily="Consolas"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LisansBannerMetin"
                               Text="Lisansınız yakında sona eriyor."
                               Foreground="#D29A22" FontFamily="Consolas" FontSize="12"
                               VerticalAlignment="Center"/>
                    <Button Content="  Lisansı Yenile →" Style="{StaticResource ChipButton}"
                            Foreground="#58A6FF" Margin="10,0,0,0" Padding="8,2"
                            Click="LisansYenile_Click"/>
                </StackPanel>
                <Button x:Name="LisansBannerKapatBtn" Grid.Column="1"
                        Content="✕" Style="{StaticResource ChipButton}"
                        Padding="6,2" Click="LisansBannerKapat_Click"/>
            </Grid>
        </Border>

        <!-- Ana içerik: TabControl + Konsol -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Ana TabControl -->
        <TabControl Grid.Row="0" x:Name="MainTabControl"
                    Margin="16,8,16,0"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#111827" BorderBrush="#243147"
                                BorderThickness="1" CornerRadius="8" Padding="4,4" Margin="0,0,0,8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                                <TabPanel IsItemsHost="True"/>
                            </ScrollViewer>
                        </Border>
                        <ContentPresenter Grid.Row="2" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Foreground" Value="#8B949E"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                        CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#0D1F2F"/>
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2F81F7"/>
                                        <Setter Property="Foreground" Value="#58A6FF"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="TabBorder" Property="Background" Value="#161B22"/>
                                        <Setter Property="Foreground" Value="#C9D1D9"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ═══ Sekme 0: Chatbot ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="●  Chatbot"/>
                </TabItem.Header>
                <DockPanel LastChildFill="True">
                    <!-- Araç çubuğu -->
                    <Border DockPanel.Dock="Top"
                            Background="#111827" BorderBrush="#243147" BorderThickness="1"
                            CornerRadius="8" Padding="10,6" Margin="0,0,0,8">
                        <WrapPanel>
                            <Button x:Name="BtnTaramaBaslat" Style="{StaticResource PrimaryButton}"
                                    Height="36" Padding="14,0" Margin="0,2,6,2"
                                    HorizontalContentAlignment="Center" Click="BtnTaramaBaslat_Click"
                                    ToolTip="Ağ arayüzlerini tespit eder ve tshark ile paket yakalamasını başlatır.">
                                <TextBlock Text="▶  Taramayı Başlat" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                            </Button>
                            <Button x:Name="BtnTaramaDurdur" Style="{StaticResource DangerButton}"
                                    Height="36" Padding="14,0" Margin="0,2,16,2"
                                    HorizontalContentAlignment="Center" IsEnabled="False"
                                    Click="BtnTaramaDurdur_Click"
                                    ToolTip="Devam eden tshark paketi yakalamayı durdurur.">
                                <TextBlock Text="■  Durdur" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnArp" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,6,2"
                                    HorizontalContentAlignment="Center" Click="BtnArp_Click"
                                    ToolTip="Yerel ağdaki IP-MAC adresi eşlemelerini listeler.">
                                <TextBlock Text="◫  ARP Tablosu" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnAgBilgi" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,6,2"
                                    HorizontalContentAlignment="Center" Click="BtnAgBilgi_Click"
                                    ToolTip="Tüm ağ adaptörlerinin IP, MAC, hız ve durumunu gösterir.">
                                <TextBlock Text="⊛  Ağ Bilgisi" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnCihazlar" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,6,2"
                                    HorizontalContentAlignment="Center" Click="BtnCihazlar_Click"
                                    ToolTip="Harici Advanced IP Scanner uygulamasını başlatır.">
                                <TextBlock Text="≡  Advanced IP Scanner" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnSadp" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,16,2"
                                    HorizontalContentAlignment="Center" Click="BtnSadp_Click"
                                    ToolTip="Hikvision SADP aracını başlatır.">
                                <TextBlock Text="⬡  SADP" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnRapor" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,6,2"
                                    HorizontalContentAlignment="Center" Click="BtnRapor_Click"
                                    ToolTip="Chat panelindeki tüm sonuçları metin dosyası olarak dışa aktarır.">
                                <TextBlock Text="▤  Rapor Kaydet" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnAyarlar" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,6,2"
                                    HorizontalContentAlignment="Center" Click="BtnAyarlar_Click"
                                    ToolTip="Uygulama ayarlarını düzenler.">
                                <TextBlock Text="⚙  Ayarlar" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnTemizle" Style="{StaticResource ActionButton}"
                                    Height="36" Padding="12,0" Margin="0,2,0,2"
                                    HorizontalContentAlignment="Center" Click="BtnTemizle_Click"
                                    ToolTip="Chat panelindeki tüm mesajları temizler.">
                                <TextBlock Text="⌫  Temizle" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                        </WrapPanel>
                    </Border>
                    <!-- AI input barı -->
                    <Border DockPanel.Dock="Bottom"
                            Background="#111827"
                            BorderBrush="#243147"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="AiInputBorder"
                                    Grid.Column="0"
                                    Background="#161B22"
                                    BorderBrush="#30363D"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8">
                                <TextBox x:Name="AiInputBox"
                                         Style="{StaticResource AiInputStyle}"
                                         Height="20"
                                         VerticalContentAlignment="Center"
                                         GotFocus="AiInputBox_GotFocus"
                                         LostFocus="AiInputBox_LostFocus"
                                         KeyDown="AiInputBox_KeyDown"/>
                            </Border>

                            <Button x:Name="AiGonderBtn"
                                    Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="36"
                                    Padding="12,0"
                                    HorizontalContentAlignment="Center"
                                    Click="AiGonderBtn_Click">
                                <TextBlock Text="✨ Sor" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                            </Button>

                            <Button x:Name="AiTemizleBtn"
                                    Grid.Column="4"
                                    Style="{StaticResource ChipButton}"
                                    Height="36"
                                    Padding="12,0"
                                    Click="AiTemizleBtn_Click">
                                <TextBlock Text="Temizle" FontFamily="Consolas" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>
                    <!-- Chat alanı — LastChildFill kalan tüm alanı doldurur -->
                    <Border Background="#0B1220" BorderBrush="#243147" BorderThickness="1" CornerRadius="10">
                        <ScrollViewer x:Name="ChatScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="4,4,8,4">
                            <StackPanel x:Name="ChatPanel" Margin="8,8,4,8"/>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══ Sekme 1: Cihaz Tara ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="◎  Cihaz Tara"/>
                </TabItem.Header>
                <Border x:Name="KameraPanel" Background="#0B1220" BorderBrush="#2F81F7" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="16,16,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="◎ CİHAZ ENVANTERİ" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Ağdaki kamera, NVR/DVR, PC, NAS, router ve servisleri canlı filtrele."
                                           Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="KameraFiltreSayacText" Grid.Column="1"
                                       Text="0 cihaz" Foreground="#58A6FF" FontFamily="Consolas"
                                       FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </Grid>
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <!-- NIC chip picker satırı -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="64">
                                    <WrapPanel x:Name="KameraSubnetChips" Orientation="Horizontal"/>
                                </ScrollViewer>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox x:Name="KameraDerinTaraCheck" Content="Derin tara"
                                              Foreground="#8B949E" FontFamily="Consolas" FontSize="11"
                                              Margin="10,0,8,0"
                                              ToolTip="Ubiquiti, MikroTik, SNMP ve WSD ek keşif protokollerini etkinleştirir. Daha yavaş ama daha kapsamlı."/>
                                    <CheckBox x:Name="KameraLiveCheck" Content="Sürekli izle"
                                              Foreground="#3FB950" FontFamily="Consolas" FontSize="11"
                                              Margin="0,0,8,0"
                                              ToolTip="Sürekli izleme modu — ARP sweep periyodik çalışır, cihazlar çevrimiçi/çevrimdışı takip edilir."/>
                                    <CheckBox x:Name="KameraDusukGuvenCheck" Content="Düşük güveni göster"
                                              Foreground="#484F58" FontFamily="Consolas" FontSize="11"
                                              Margin="0,0,8,0"
                                              ToolTip="Güven skoru 12 altındaki ve çevrimdışı cihazları da listele. Varsayılan: gizli."
                                              Checked="KameraDusukGuvenCheck_Changed"
                                              Unchecked="KameraDusukGuvenCheck_Changed"/>
                                </StackPanel>
                                <Button x:Name="KameraNicYenileBtn" Grid.Column="2" Content="⟳"
                                        Width="34" Height="30" FontSize="14"
                                        Background="#1F2933" Foreground="#58A6FF" BorderBrush="#2F81F7" BorderThickness="1"
                                        Click="KameraNicYenileBtn_Click"
                                        ToolTip="Ağ arayüzlerini yeniden tara"/>
                            </Grid>
                            <!-- Manuel subnet input + Tara/Durdur + AI -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <TextBox x:Name="KameraSubnetBox" Style="{StaticResource PingInputBox}"
                                             Padding="10,8,10,8" TextChanged="KameraSubnetBox_TextChanged"/>
                                    <TextBlock x:Name="KameraSubnetPlaceholder" Text="Subnet/CIDR: 192.168.1 veya 192.168.1.0/24"
                                               FontFamily="Consolas" FontSize="12" Foreground="#484F58"
                                               VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                </Grid>
                                <Button x:Name="KameraBaslatBtn" Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                        Height="38" HorizontalContentAlignment="Center" Click="KameraBaslatBtn_Click"
                                        ToolTip="Girilen subnet/CIDR aralığını tarar ve cihaz envanterini günceller.">
                                    <TextBlock Text="◎  Tara  ⓘ" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                                </Button>
                                <Button x:Name="KameraDurdurBtn" Grid.Column="3" Content="■"
                                        Style="{StaticResource DangerButton}" Height="38"
                                        HorizontalContentAlignment="Center"
                                        Visibility="Collapsed" Click="KameraDurdurBtn_Click"/>
                                <Button x:Name="KameraAiBtn" Grid.Column="5"
                                        Style="{StaticResource ActionButton}"
                                        Height="38" Padding="12,0"
                                        IsEnabled="False"
                                        HorizontalContentAlignment="Center"
                                        Click="KameraAiBtn_Click"
                                        ToolTip="Taranan cihazları AI ile analiz et (tarama tamamlandıktan sonra aktif olur)">
                                    <TextBlock Text="✨ AI" FontFamily="Consolas" FontSize="12"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="KameraIpFiltreBox" Style="{StaticResource PingInputBox}" Padding="9,7"
                                         TextChanged="KameraKolonFiltre_TextChanged"
                                         ToolTip="IP sütununa göre filtreler. Örn: 192.168.1.24 veya 192.168.1"/>
                                <TextBlock x:Name="KameraIpFiltrePlaceholder" Text="IP filtre" FontFamily="Consolas" FontSize="10" Foreground="#484F58" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                            <Grid Grid.Column="2">
                                <TextBox x:Name="KameraAdFiltreBox" Style="{StaticResource PingInputBox}" Padding="9,7"
                                         TextChanged="KameraKolonFiltre_TextChanged"
                                         ToolTip="Ad ve model sütunlarını birlikte filtreler. Hostname, cihaz adı veya model yazabilirsiniz."/>
                                <TextBlock x:Name="KameraAdFiltrePlaceholder" Text="Ad / hostname" FontFamily="Consolas" FontSize="10" Foreground="#484F58" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                            <ComboBox x:Name="KameraTurFiltreBox" Grid.Column="4"
                                       Style="{StaticResource DarkComboBox}"
                                       SelectedIndex="0" SelectionChanged="KameraTurFiltreDegisti" Padding="8,6"
                                       ToolTip="Tür sütununa göre filtreler (Kamera, NVR/DVR, Bilgisayar vb.).">
                                <ComboBoxItem Content="Tüm türler" Tag="Hepsi"/>
                                <ComboBoxItem Content="Bilinmiyor" Tag="Bilinmiyor"/>
                                <ComboBoxItem Content="Kamera" Tag="Kamera"/>
                                <ComboBoxItem Content="NVR/DVR" Tag="NVR/DVR"/>
                                <ComboBoxItem Content="Bilgisayar" Tag="Bilgisayar"/>
                                <ComboBoxItem Content="Linux IoT" Tag="Linux IoT"/>
                                <ComboBoxItem Content="NAS" Tag="NAS"/>
                                <ComboBoxItem Content="Sunucu" Tag="Sunucu"/>
                                <ComboBoxItem Content="Router/Switch" Tag="Router/Switch"/>
                                <ComboBoxItem Content="Router/AP" Tag="Router/AP"/>
                                <ComboBoxItem Content="Erişim Noktası" Tag="Erişim Noktası"/>
                                <ComboBoxItem Content="Switch" Tag="Switch"/>
                                <ComboBoxItem Content="Güvenlik Duvarı" Tag="Güvenlik Duvarı"/>
                                <ComboBoxItem Content="Yazıcı" Tag="Yazıcı"/>
                                <ComboBoxItem Content="Akıllı TV" Tag="Akıllı TV"/>
                                <ComboBoxItem Content="Akıllı Cihaz" Tag="Akıllı Cihaz"/>
                                <ComboBoxItem Content="Telefon" Tag="Telefon"/>
                                <ComboBoxItem Content="Hoparlör" Tag="Hoparlör"/>
                            </ComboBox>
                            <Grid Grid.Column="6">
                                <TextBox x:Name="KameraMarkaFiltreBox" Style="{StaticResource PingInputBox}" Padding="9,7"
                                         TextChanged="KameraKolonFiltre_TextChanged"
                                         ToolTip="Marka ve üretici sütunlarını filtreler. Örn: Hikvision, Dahua, TP-Link"/>
                                <TextBlock x:Name="KameraMarkaFiltrePlaceholder" Text="Marka / üretici" FontFamily="Consolas" FontSize="10" Foreground="#484F58" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                            <Grid Grid.Column="8">
                                <TextBox x:Name="KameraPortFiltreBox" Style="{StaticResource PingInputBox}" Padding="9,7"
                                         TextChanged="KameraKolonFiltre_TextChanged"
                                         ToolTip="Portlar, servis ve keşif sütunlarını birlikte filtreler. Örn: 554, ONVIF, RTSP"/>
                                <TextBlock x:Name="KameraPortFiltrePlaceholder" Text="Port / servis" FontFamily="Consolas" FontSize="10" Foreground="#484F58" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                            <Grid Grid.Column="10">
                                <TextBox x:Name="KameraMacFiltreBox" Style="{StaticResource PingInputBox}" Padding="9,7"
                                         TextChanged="KameraKolonFiltre_TextChanged"
                                         ToolTip="MAC sütununa göre filtreler. Tam MAC veya parça yazabilirsiniz."/>
                                <TextBlock x:Name="KameraMacFiltrePlaceholder" Text="MAC" FontFamily="Consolas" FontSize="10" Foreground="#484F58" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                            <StackPanel Grid.Column="12" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Filtreyi Temizle  ⓘ" Style="{StaticResource ChipButton}"
                                        ToolTip="Tüm filtre kutularını sıfırlar ve tüm satırları tekrar gösterir."
                                        Click="KameraFiltreTemizle_Click" Margin="0,0,6,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="KameraIlerlemeText" Grid.Row="3"
                                   Foreground="#6E7681" FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed" TextWrapping="Wrap"/>
                        <Border x:Name="KameraResultBorder" Grid.Row="4" Background="#0D1117"
                                BorderBrush="#243147" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                            <DataGrid x:Name="KameraDataGrid" Style="{StaticResource DarkDataGrid}"
                                      Margin="1"
                                      PreviewMouseRightButtonDown="KameraDataGrid_PreviewMouseRightButtonDown"
                                      MouseDoubleClick="KameraDataGrid_MouseDoubleClick">
                                <DataGrid.ContextMenu>
                                    <ContextMenu Style="{StaticResource FlatContextMenu}">
                                        <ContextMenu.Resources>
                                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource FlatContextMenuItem}"/>
                                        </ContextMenu.Resources>
                                        <MenuItem Header="Web arayüzünü aç" Click="KameraMenuWeb_Click"/>
                                        <MenuItem Header="Bu cihazı yeniden tara" Click="KameraMenuYenidenTara_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Ping at" Click="KameraMenuPing_Click"/>
                                        <MenuItem Header="Port tara" Click="KameraMenuPort_Click"/>
                                        <MenuItem Header="Traceroute" Click="KameraMenuTrace_Click"/>
                                        <MenuItem Header="DNS lookup" Click="KameraMenuDns_Click"/>
                                        <Separator/>
                                        <MenuItem Header="IP kopyala" Click="KameraMenuIpKopyala_Click"/>
                                        <MenuItem Header="Favorilere ekle" Click="KameraMenuFavoriEkle_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Excel dışa aktar" Click="KameraExportExcel_Click"/>
                                        <MenuItem Header="PDF dışa aktar" Click="KameraExportPdf_Click"/>
                                        <MenuItem Header="TXT dışa aktar" Click="KameraExportTxt_Click"/>
                                        <MenuItem Header="CSV dışa aktar" Click="KameraExportCsv_Click"/>
                                        <MenuItem Header="JSON dışa aktar" Click="KameraExportJson_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Ip}" SortMemberPath="Ip" Width="118">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="IP ⓘ" ToolTip="Cihazın IPv4 adresi."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Ad}" SortMemberPath="Ad" Width="140">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Ad ⓘ" ToolTip="NetBIOS/DNS/hostname veya cihaz adı."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Tur}" SortMemberPath="Tur" Width="115">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Tür ⓘ" ToolTip="Algılanan cihaz sınıfı (Kamera, NVR, Bilgisayar vb.)."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Marka}" SortMemberPath="Marka" Width="105">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Marka ⓘ" ToolTip="Cihaz markası (banner, OUI veya keşif bilgisinden)."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Model}" SortMemberPath="Model" Width="130">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Model ⓘ" ToolTip="Algılanan model/hardware metni."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Os}" SortMemberPath="Os" Width="90">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="OS ⓘ" ToolTip="İşletim sistemi (SSH banner, SMB veya SNMP'den algılanır)."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Durum}" SortMemberPath="Durum" Width="75">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Durum ⓘ" ToolTip="Cihazın ağdaki güncel durumu (Online / Offline)."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding SonGorulen}" SortMemberPath="SonGorulen" Width="80">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Son Görülme ⓘ" ToolTip="Cihazın son yanıt verdiği zaman."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Ping}" SortMemberPath="PingMs" Width="70">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Ping ⓘ" ToolTip="ICMP gecikme süresi (ms)."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Portlar}" SortMemberPath="Portlar" Width="120">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Portlar ⓘ" ToolTip="Açık tespit edilen TCP portları."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Kesif}" SortMemberPath="Kesif" Width="130">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Keşif ⓘ" ToolTip="Cihazı tanımlayan keşif protokolleri (ONVIF, mDNS, SNMP vb.)."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn SortMemberPath="Guven" Width="60">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="Güven ⓘ" ToolTip="Cihaz tanıma güven skoru (0-100). Birden çok kaynaktan doğrulanan cihazlar yüksek skor alır."/>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Guven}" FontFamily="Consolas" FontSize="11"
                                                           Padding="4,2" TextAlignment="Center"
                                                           ToolTip="{Binding KararIzi}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#8B949E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GuvenRenk}" Value="Kirmizi">
                                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding GuvenRenk}" Value="Sari">
                                                                    <Setter Property="Foreground" Value="#D29922"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding GuvenRenk}" Value="Yesil">
                                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Binding="{Binding Mac}" SortMemberPath="Mac" Width="130">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="MAC ⓘ" ToolTip="Cihazın MAC adresi."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Uretici}" SortMemberPath="Uretici" Width="130">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Üretici ⓘ" ToolTip="MAC OUI veya keşiften üretici bilgisi."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Servis}" SortMemberPath="Servis" Width="220">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Servis ⓘ" ToolTip="Port bazlı servis/banner detayları."/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 2: Ping Testi ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="◈  Ping Testi"/>
                </TabItem.Header>
                <Border x:Name="PingPanel" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="◈ PING TESTİ" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Hangi IP'ye atmak istiyorsunuz?" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <TextBox x:Name="PingIpBox" Style="{StaticResource PingInputBox}" Padding="10,8,34,8"
                                     TextChanged="PingIpBox_TextChanged" KeyDown="PingIpBox_KeyDown"/>
                            <TextBlock x:Name="PingPlaceholder" Text="Örn: 192.168.1.1"
                                       FontFamily="Consolas" FontSize="13" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="PingValidasyonIkonu" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       FontFamily="Consolas" FontSize="15" FontWeight="Bold" IsHitTestVisible="False"/>
                        </Grid>
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="HIZLI SEÇİM" Foreground="#484F58" FontFamily="Consolas" FontSize="10" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Style="{StaticResource ChipButton}" Tag="192.168.1.1"   Content="192.168.1.1"   Click="PingHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="192.168.1.254" Content="192.168.1.254" Click="PingHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="8.8.8.8"       Content="8.8.8.8"       Click="PingHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="1.1.1.1"       Content="1.1.1.1"       Click="PingHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="8.8.4.4"       Content="8.8.4.4"       Click="PingHizliBtn_Click"/>
                                <Button Style="{StaticResource ChipButton}" Tag="google.com"    Content="google.com"    Click="PingHizliBtn_Click"/>
                            </WrapPanel>
                            <WrapPanel x:Name="PingFavorilerPanel" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Row="3" Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PingBaslatBtn" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                    IsEnabled="False" Height="36" HorizontalContentAlignment="Center"
                                    Click="PingBaslatBtn_Click">
                                <TextBlock Text="◈  Ping Başlat" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                            </Button>
                            <Button x:Name="PingFavoriEkleBtn" Grid.Column="2" Content="★"
                                    Style="{StaticResource ActionButton}" IsEnabled="False" Height="36"
                                    HorizontalContentAlignment="Center" ToolTip="Favoriye Ekle"
                                    Click="PingFavoriEkle_Click"/>
                        </Grid>
                        <Border x:Name="PingResultBorder" Grid.Row="4" Background="#0D1117"
                                BorderBrush="#21262D" BorderThickness="1" CornerRadius="6"
                                Margin="0,8,0,0" Visibility="Collapsed">
                            <ScrollViewer x:Name="PingResultScroll" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="PingResultPanel" Margin="10,8,10,8"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ Sekme 3: Port Tara ═══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock FontFamily="Consolas" FontSize="12" Text="⊞  Port Tara"/>
                </TabItem.Header>
