                </Button>

                <!-- Ayırıcı -->
                <Rectangle Height="1" Fill="#21262D" Margin="0,8,0,8"/>

                <!-- Rapor Kaydet -->
                <Button x:Name="BtnRapor"
                        Style="{StaticResource ActionButton}"
                        Click="BtnRapor_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▤  " FontSize="13"/>
                        <TextBlock Text="Rapor Kaydet" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Ayarlar -->
                <Button x:Name="BtnAyarlar"
                        Style="{StaticResource ActionButton}"
                        Click="BtnAyarlar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙  " FontSize="13"/>
                        <TextBlock Text="Ayarlar" FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- Ayırıcı -->
                <Rectangle Height="1" Fill="#21262D" Margin="0,8,0,8"/>

                <!-- Temizle -->
                <Button x:Name="BtnTemizle"
                        Style="{StaticResource ActionButton}"
                        Click="BtnTemizle_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌫  " FontSize="13"/>
                        <TextBlock Text="Ekranı Temizle" FontSize="13"/>
                    </StackPanel>
                </Button>

            </StackPanel>
            </ScrollViewer>

            <!-- Alt: Versiyon bilgisi -->
            <TextBlock Grid.Row="2"
                       Text="v0.1.0 — Ağ Tarama"
                       Foreground="#484F58"
                       FontSize="10"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"/>
        </Grid>

        <!-- Toast bildirimi overlay (tüm kolonları kaplar, sağ alt köşe) -->
        <Border x:Name="ToastBildirim"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Background="#1C2128"
                BorderBrush="#3FB950"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Visibility="Collapsed"
                Panel.ZIndex="200">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIkon"
                           Text="✔"
                           Foreground="#3FB950"
                           FontFamily="Consolas"
                           FontSize="13"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock x:Name="ToastMetin"
                           Foreground="#E6EDF3"
                           FontFamily="Consolas"
                           FontSize="12"
                           MaxWidth="260"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
