                                    <StackPanel>
                                        <TextBlock Text="AVG ↓" Foreground="#484F58" FontFamily="Consolas" FontSize="9"/>
                                        <TextBlock x:Name="BantStatAvgRx" Text="—"
                                                   Foreground="#58A6FF" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
