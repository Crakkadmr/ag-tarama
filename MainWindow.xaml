                    <Grid Margin="20,16,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="⊞ PORT TARA" Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="IP ve port aralığı girin:" Foreground="#8B949E" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBox x:Name="PortIpBox" Style="{StaticResource PingInputBox}" Padding="10,8,34,8"
                                     TextChanged="PortIpBox_TextChanged" KeyDown="PortIpBox_KeyDown"/>
                            <TextBlock x:Name="PortIpPlaceholder" Text="Hedef IP"
                                       FontFamily="Consolas" FontSize="13" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="PortIpValidasyon" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       FontFamily="Consolas" FontSize="15" FontWeight="Bold" IsHitTestVisible="False"/>
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <TextBox x:Name="PortAralikBox" Style="{StaticResource PingInputBox}" Padding="10,8,10,8"
                                     TextChanged="PortAralikBox_TextChanged"/>
                            <TextBlock x:Name="PortAralikPlaceholder" Text="Portlar: 1-1024, 80,443"
                                       FontFamily="Consolas" FontSize="11" Foreground="#484F58"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Grid Grid.Row="3" Margin="0,0,0,4">
                            <Grid.RowDefinitions>
